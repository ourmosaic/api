generator client {
  provider = "prisma-client-js"
}

generator nestjsDto {
  provider                        = "prisma-generator-nestjs-dto"
  output                          = "../src/@generated/prisma-nestjs-dto"
  outputToNestJsResourceStructure = "false"
  exportRelationModifierClasses   = "true"
  reExport                        = "false"
  createDtoPrefix                 = "Create"
  updateDtoPrefix                 = "Update"
  dtoSuffix                       = "Dto"
  entityPrefix                    = ""
  entitySuffix                    = ""
}

datasource db {
  provider = "postgresql"
}

enum PrivacyLevel {
  PRIVATE
  FRIENDS
  PUBLIC
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum CustomFieldType {
  STRING
  LONG_TEXT
  COLOR
  DATE
  DATE_DAY_MONTH
  DATETIME
  DATE_MONTH_YEAR
  NUMBER
}

enum FriendshipType {
  FRIENDS
  SUPERFRIENDS
}

enum ReportType {
  SYSTEM
  USER
  MEMBER
}

enum BlockType {
  SYSTEM
  USER
  MEMBER
}

model Report {
  id          String     @id @default(uuid())
  type        ReportType
  description String?
  createdAt   DateTime   @default(now())
  reporterId  String
  reporter    User       @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  ReportSystem ReportSystem?
  ReportUser   ReportUser?
  ReportMember ReportMember?
}

model ReportSystem {
  id        String   @id @default(uuid())
  reportId  String   @unique
  systemId  String
  reason    String?
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  system System @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

model ReportUser {
  id        String   @id @default(uuid())
  reportId  String   @unique
  userId    String
  reason    String?
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReportMember {
  id        String   @id @default(uuid())
  reportId  String   @unique
  memberId  String
  reason    String?
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model BlockedUser {
  id        String   @id @default(uuid())
  blockerId String
  blocker   User     @relation("UserBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("UserBlocked", fields: [blockedId], references: [id], onDelete: Cascade)
  reason    String?
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model BlockedMember {
  id        String   @id @default(uuid())
  blockerId String
  blocker   User     @relation("MemberBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   Member   @relation("MemberBlocked", fields: [blockedId], references: [id], onDelete: Cascade)
  reason    String?
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model BlockedSystem {
  id        String   @id @default(uuid())
  blockerId String
  blocker   User     @relation("SystemBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   System   @relation("SystemBlocked", fields: [blockedId], references: [id], onDelete: Cascade)
  reason    String?
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  email       String   @unique
  password    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isFederated Boolean  @default(false)
  domain      String?
  distantId   String?
  fedePerms   Int      @default(0) // permissions sur la fede (bitfield)

  isSystem Boolean @default(false) // Permet de savoir rapidement si l'utilisateur est un système
  system   System?

  sentFriendRequests     Friendship[] @relation("UserOne")
  receivedFriendRequests Friendship[] @relation("UserTwo")
  ReportUser             ReportUser[]
  Report                 Report[]

  // Blocages
  usersBlocked   BlockedUser[]   @relation("UserBlocker")
  blockedByUsers BlockedUser[]   @relation("UserBlocked")
  membersBlocked BlockedMember[] @relation("MemberBlocker")
  systemsBlocked BlockedSystem[] @relation("SystemBlocker")

  @@unique([distantId, domain])
}

model System {
  id           String       @id @default(uuid())
  customName   String?
  avatarUrl    String?
  description  String?
  color        String?
  domain       String?
  distantId    String? // ID distant pour les systèmes fédérés
  frontPrivacy PrivacyLevel @default(PRIVATE)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  members       Member[]
  groups        Group[]
  frontSessions FrontSession[]
  customFields  CustomField[]

  channels Channel[]

  channelCategories ChannelCategory[]
  ReportSystem      ReportSystem[]
  blockedByUsers    BlockedSystem[]   @relation("SystemBlocked")
}

model Member {
  id          String       @id @default(uuid())
  name        String
  pronouns    String?
  avatarUrl   String?
  role        String?
  description String?
  domain      String?
  color       String?
  distantId   String? // ID distant pour les membres fédérés
  inDormancy  Boolean      @default(false)
  privacy     PrivacyLevel @default(PRIVATE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  frontSessions     FrontSession[]
  groups            MemberOnGroups[]
  customFieldValues CustomFieldValue[]

  chatMessages ChatMessage[]

  boardMessagesSent     BoardMessage[]  @relation("BoardMessageFrom")
  boardMessagesReceived BoardMessage[]  @relation("BoardMessageTo")
  ReportMember          ReportMember[]
  blockedByUsers        BlockedMember[] @relation("MemberBlocked")

  @@unique([distantId, domain])
}

model Group {
  id        String   @id @default(uuid())
  name      String
  color     String?
  icon      String?
  domain    String?
  distantId String? // ID distant pour les groupes fédérés
  createdAt DateTime @default(now())

  parentId String? @default("root")
  parent   Group?  @relation("GroupToGroup", fields: [parentId], references: [id])
  children Group[] @relation("GroupToGroup")

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  members MemberOnGroups[]
}

model MemberOnGroups {
  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@id([memberId, groupId])
}

model FrontSession {
  id        String    @id @default(uuid())
  startTime DateTime  @default(now())
  endTime   DateTime?
  notes     String?

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model CustomField {
  id      String          @id @default(uuid())
  name    String
  type    CustomFieldType @default(STRING)
  order   Int             @default(0)
  privacy PrivacyLevel    @default(PRIVATE)

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  values CustomFieldValue[]
}

model CustomFieldValue {
  id    String @id @default(uuid())
  value String

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  customFieldId String
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([memberId, customFieldId])
}

model ChannelCategory {
  id   String  @id @default(uuid())
  name String
  desc String?

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  channels Channel[]
}

model Channel {
  id          String  @id @default(uuid())
  name        String
  description String?
  categoryId  String?

  category ChannelCategory? @relation(fields: [categoryId], references: [id])

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  chatMessages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(uuid())
  content   String
  timestamp DateTime @default(now())

  senderId String
  sender   Member @relation(fields: [senderId], references: [id], onDelete: Cascade)

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model BoardMessage {
  id        String   @id @default(uuid())
  content   String
  timestamp DateTime @default(now())
  read      Boolean  @default(false)

  fromId String
  from   Member @relation("BoardMessageFrom", fields: [fromId], references: [id], onDelete: Cascade)

  toId String
  to   Member @relation("BoardMessageTo", fields: [toId], references: [id], onDelete: Cascade)
}

model KnownFederation {
  id        String   @id @default(uuid())
  url       String   @unique
  publicKey String
  createdAt DateTime @default(now())
}

model Friendship {
  id                           String           @id @default(uuid())
  status                       FriendshipStatus @default(PENDING)
  createdAt                    DateTime         @default(now())
  type                         FriendshipType   @default(FRIENDS)
  canViewFront                 Boolean          @default(false)
  canReceiveFrontNotifications Boolean          @default(false)
  canViewSharedMembers         Boolean          @default(false)
  notifyMeOnFriendFrontChange  Boolean          @default(false)

  // sender
  userOneId String
  userOne   User   @relation("UserOne", fields: [userOneId], references: [id], onDelete: Cascade)

  // reciever
  userTwoId String
  userTwo   User   @relation("UserTwo", fields: [userTwoId], references: [id], onDelete: Cascade)

  @@unique([userOneId, userTwoId])
}
